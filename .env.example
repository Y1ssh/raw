# ==========================================================================
# Raw — environment configuration (COPY to .env, never commit .env)
# Every value here is a SLOT selector or a credential. Config-over-code.
# ==========================================================================

# ---- Core ----
RAW_ENV=dev                       # dev | staging | prod
RAW_LOG_LEVEL=INFO

# ---- LLM gateway (LiteLLM) ----  ⚠️ pin the litellm version in pyproject
RAW_LLM_MODEL=ollama/qwen2.5:3b   # any LiteLLM model string
RAW_LLM_FALLBACK=                 # optional secondary model for failover
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# ---- State / persistence (Postgres) ----
RAW_POSTGRES_URL=postgresql://raw:raw@localhost:5432/raw

# ---- Cache / queue (Redis) ----
RAW_REDIS_URL=redis://localhost:6379/0

# ---- Vector slot (OPTIONAL — packs enable retrieval) ----
RAW_VECTOR_PROVIDER=pgvector      # pgvector | qdrant | none
# RAW_QDRANT_URL=http://localhost:6333

# ---- Guardrails ----
RAW_MAX_ITERATIONS=10             # hard loop cap (no infinite loops)

# ---- Observability (Langfuse — optional) ----
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3000

# ---- Pack ----
RAW_PACK_PATH=./example-pack      # swap this path -> a different agent
